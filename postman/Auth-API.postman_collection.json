{
  "info": {
    "name": "Auth API - Bearer Token",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "User authentication and authorization with JWT Bearer tokens. Run Register -> Login -> Get Me. The Login request saves the JWT to the {{token}} collection variable; Get Me uses it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "Create a new user. Body: { username, email, password }. Returns 201 with the created user's id, username, email, createdAt. 409 if email/username already exists. 400 on validation errors."
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json && json.token) {",
              "    pm.collectionVariables.set('token', json.token);",
              "    console.log('Token saved to collection variable {{token}}');",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Authenticate. Body: { email, password }. Returns 200 with a JWT (also auto-saved to {{token}}). 401 on bad credentials."
      }
    },
    {
      "name": "Get Me (protected)",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "me"]
        },
        "description": "Returns the current user's info, decoded from the Bearer JWT. Requires Authorization: Bearer <token>. 401 on missing/invalid/expired token."
      }
    }
  ]
}
